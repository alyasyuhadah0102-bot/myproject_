    font-size: 18px;
    color: #444;
}

ul{
    line-height: 1.8;
}

hr{
    border: none;
    height: 2px;
    background: #ffd6e8;
}

.profile{
    text-align: center;
}

.profile img{
    width: 150px;
    height: 150px;
    border-radius: 50%;
    border: 5px solid #ff99cc;
}

.button{
    display: inline-block;
    padding: 12px 20px;
    background: #ff66b2;
    color: white;
    text-decoration: none;
    border-radius: 10px;
    margin-top: 15px;
}

.button:hover{
    background: #ff3385;
}

</style>

</head>

