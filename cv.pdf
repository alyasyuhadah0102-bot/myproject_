.container{
    background: white;
    padding: 35px;
    border-radius: 20px;
    width: 70%;
    margin: auto;
    box-shadow: 0 0 20px rgba(0,0,0,0.2);
}

h1{
    color: #ff4da6;
    text-align: center;
